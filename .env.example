# Assembla personal key with BOTH "API access" and "Repository access" enabled.
# Create at: My Profile -> API Applications & Sessions -> Register new personal key
ASSEMBLA_API_KEY=your_key_here
ASSEMBLA_API_SECRET=your_secret_here

# Only required for spaces that contain an SVN repository. SVN over HTTPS
# authenticates with your Assembla login name plus the API secret as password.
ASSEMBLA_USERNAME=your_assembla_login

